<!-- Hiwonder 5 DOF robot arm for education and testing -->

<robot name="hiwonder_robot">

     <!-- BASE  -->
    <link name="base_link"/>
      
    <link name="link1">
      <visual>
            <geometry>
                <box size="0.03 0.03 0.155"/>
            </geometry>
            <origin xyz="0 0 0.0775" rpy="0 0 0"/>
            <material name="base_color">
                <color rgba="0.5 0.3 0.3 1.0"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <box size="0.03 0.03 0.155"/>
            </geometry>
            <origin xyz="0 0 0.0775" rpy="0 0 0"/>
        </collision>
    </link>

    <!-- LINK 2 -->
    <link name="link2">
        <visual>
            <geometry>
                <box size="0.03 0.03 0.099"/>
            </geometry>
            <origin xyz="0 -0.04975 0" rpy="-1.5708 0 0"/>
            <material name="base_color">
                <color rgba="0.5 0.3 0.3 1.0"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <box size="0.03 0.03 0.099"/>
            </geometry>
            <origin xyz="0 -0.04975 0" rpy="-1.5708 0 0"/>
        </collision>
    </link>

      <!-- LINK 3 -->
    <link name="link3">
        <visual>
            <geometry>
                <box size="0.03 0.03 0.095"/>
            </geometry>
            <origin xyz="0.0475 0 0" rpy="1.5708 0 -1.5708"/>
            <material name="base_color">
                <color rgba="0.5 0.3 0.3 1.0"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <box size="0.03 0.03 0.095"/>
            </geometry>
            <origin xyz="0.0475 0 0" rpy="1.5708 0 -1.5708"/>
        </collision>
    </link>

      <!-- LINK 4 -->
    <link name="link4">
        <visual>
            <geometry>
                <box size="0.03 0.03 0.055"/>
            </geometry>
            <origin xyz="0.0275 0 0" rpy="1.5708 0 -1.5708"/>
            <material name="base_color">
                <color rgba="0.5 0.3 0.3 1.0"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <box size="0.03 0.03 0.055"/>
            </geometry>
            <origin xyz="0.0275 0 0" rpy="1.5708 0 -1.5708"/>
        </collision>
    </link>

    <!-- LINK 5 -->
    <link name="link5">
        <visual>
            <geometry>
                <box size="0.02 0.01 0.105"/>
            </geometry>
            <origin xyz="0 0 0.0525" rpy="0 0 0"/>
            <material name="red5">
                <color rgba="0.5 0.2 0.15 1.0"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <box size="0.02 0.01 0.105"/>
            </geometry>
            <origin xyz="0 0 0.0525" rpy="0 0 0"/>
        </collision>
    </link>

    <!-- End Effector Link -->
    <link name="ee" />
  


    <!-- JOINT 1 -->
    <joint name="joint1" type="revolute">
        <parent link="base_link"/>
        <child link="link1"/>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <axis rpy="0 0 0" xyz="0 0 1"/> 
        <limit lower="-3.14" upper="3.14" velocity="3.14" effort="1000" />
    </joint>

    <!-- JOINT 2 -->
    <joint name="joint2" type="revolute">
        <parent link="link1"/>
        <child link="link2"/>
        <origin rpy="-1.5708 0 0" xyz="0 0 0.155"/>
        <axis rpy="0 0 0" xyz="0 0 1"/> 
        <limit lower="-3.14" upper="3.14" velocity="3.14" effort="1000" />
    </joint>

    <!-- JOINT 3 -->
    <joint name="joint3" type="revolute">
        <parent link="link2"/>
        <child link="link3"/>
        <origin rpy="3.142 0 -1.5708" xyz="0 -0.099 0"/>
        <axis rpy="0 0 0" xyz="0 0 1"/> 
        <limit lower="-3.14" upper="3.14" velocity="3.14" effort="1000" />
    </joint>

    <!-- JOINT 4 -->
    <joint name="joint4" type="revolute">
        <parent link="link3"/>
        <child link="link4"/>
        <origin rpy="3.142 0 0" xyz="0.095 0 0"/>
        <axis rpy="0 0 0" xyz="0 0 1"/> 
        <limit lower="-3.14" upper="3.14" velocity="3.14" effort="1000" />
    </joint>

    <!-- JOINT 5 -->
    <joint name="joint5" type="revolute">
        <parent link="link4"/>
        <child link="link5"/>
        <origin rpy="1.5708 0 1.5708" xyz="0.055 0 0"/>
        <axis rpy="0 0 0" xyz="0 0 1"/> 
        <limit lower="-3.14" upper="3.14" velocity="3.14" effort="1000" />
    </joint>

    <!-- End Effector Joint -->
    <joint name="ee_joint" type="fixed">
        <parent link="link5"/>
        <child link="ee"/>
        <origin rpy="0 0 0" xyz="0 0 0.105"/>
    </joint>

</robot>

